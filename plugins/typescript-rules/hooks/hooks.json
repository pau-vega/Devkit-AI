{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/enforce-pnpm.sh"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/lint-before-commit.sh"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/typecheck-before-commit.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/no-package-json-edit.sh"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/no-enum.sh"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/no-export-default.sh"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/no-any.sh"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/no-inline-import-type.sh"
          },
          {
            "type": "prompt",
            "prompt": "Check if the target file is .ts or .tsx. If not, respond with 'approve'. If it is a TypeScript file, validate the proposed code against these rules: (1) No 'type A = X & Y' for inheritance — use 'interface extends' instead, (2) No 'T | undefined' for optional props — use 'prop?: T'. If all rules pass, respond 'approve'. If any rule is violated, respond 'deny' with an explanation of which rules were broken and how to fix them."
          }
        ]
      }
    ]
  }
}
